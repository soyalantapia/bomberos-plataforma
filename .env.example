###############################################################################
# Faro · variables de entorno
# Copiá este archivo a .env y completá los valores.
# NUNCA commitees el .env real (está en .gitignore).
###############################################################################

# --- Base de datos -----------------------------------------------------------
DATABASE_URL="postgresql://faro:faro_dev_password@localhost:5432/faro?schema=public"

# --- Cache / colas -----------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# --- Better Auth (OTP) -------------------------------------------------------
# Generá un secret fuerte: openssl rand -hex 32
BETTER_AUTH_SECRET="reemplazar_con_32_bytes_aleatorios_en_hex"
BETTER_AUTH_URL="http://localhost:3000"

# Proveedor de OTP (Twilio / Meta WhatsApp / Resend) — se completa luego.
OTP_PROVIDER="console"

# --- Anthropic (IA) ----------------------------------------------------------
# Pedila en https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# --- API ---------------------------------------------------------------------
PORT=3001
WEB_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# --- Web ---------------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
